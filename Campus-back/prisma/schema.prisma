generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  PENDING
  WAITLIST
  INTERVIEW
  ACCEPTED
  REJECTED
  APPROVED
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  name           String
  role           Role
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  student        StudentProfile?
  company        CompanyProfile?
  actorAuditLogs AuditLog[]      @relation("ActorAuditLogs")
  notifications  Notification[]
}

model StudentProfile {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique
  user            User          @relation(fields: [userId], references: [id])
  resumeUrl       String?
  phone           String?
  location        String?
  education       String?
  degree          String?
  age             Int?
  skills          String[]      @default([])
  bio             String?
  linkedin        String?
  github          String?
  website         String?
  experience      String?
  experienceYears Int?
  profileImageUrl String?
  applications    Application[]
}

model CompanyProfile {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
  name         String
  website      String?
  location     String?
  contactPhone String?
  about        String?
  imageUrl     String?
  jobs         Job[]
}

model Job {
  id           Int            @id @default(autoincrement())
  title        String
  description  String
  location     String?
  type         JobType        @default(FULL_TIME)
  requiredSkills String[]     @default([])
  requiredDegree String?
  minAge         Int?
  maxAge         Int?
  minExperienceYears Int?
  interviewDates DateTime[]   @default([])
  interviewStartTime String?
  interviewCandidatesPerDay Int?
  companyId    Int
  company      CompanyProfile @relation(fields: [companyId], references: [id])
  createdAt    DateTime       @default(now())
  applications Application[]

  @@index([companyId, createdAt])
}

model Application {
  id        Int               @id @default(autoincrement())
  jobId     Int
  studentId Int
  status    ApplicationStatus @default(PENDING)
  matchScore Int              @default(0)
  matchSummary Json?
  interviewDate DateTime?
  interviewStartTime String?
  interviewQueueNumber Int?
  waitlistRank Int?
  interviewNote String?
  manualInterviewOverride Boolean @default(false)
  createdAt DateTime          @default(now())
  job       Job               @relation(fields: [jobId], references: [id])
  student   StudentProfile    @relation(fields: [studentId], references: [id])

  @@unique([jobId, studentId])
  @@index([status, createdAt])
  @@index([jobId, status, matchScore])
  @@index([jobId, interviewDate, interviewQueueNumber])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
